/* 
start ribbon set
dark style theme 2
*/

/*SARibbonApplicationWidget*/
SARibbonApplicationWidget{
    background-color: {{accent}};
    border: solid {{accent}};
    color:{{ribbon-text}};
}

/*SARibbonBar*/
SARibbonBar{
  background-color: {{accent}};
  border: solid {{accent}};
  color: {{text-color}};
}


/*SARibbonButtonGroupWidget,SARibbonSystemButtonBar和RightButtonGroup都是使用此控件，pannel里面的按钮组也是使用此控件*/
SARibbonButtonGroupWidget{
  background-color: transparent;
}

/* SARibbonButtonGroupWidget下按钮设置*/
SARibbonButtonGroupWidget > QToolButton {
    border: none;
    color: {{text-color}};
    background-color: transparent;
    padding: 0 2px;
}
/* SARibbonButtonGroupWidget下ToolButton按钮 hover.pressed.checked 状态 */
SARibbonButtonGroupWidget > QToolButton:hover {
    background-color: {{content-pressed-bg}};
}
SARibbonButtonGroupWidget > QToolButton:pressed{
    background-color: {{content-pressed-bg}};
    border:1px solid {{border-color}};
}
SARibbonButtonGroupWidget > QToolButton:checked {
    background-color: {{content-pressed-bg}};
    border:1px solid {{border-color}};
}
/* SARibbonButtonGroupWidget下ToolButton按钮 菜单状态 */
/*MenuButtonPopup*/
SARibbonButtonGroupWidget > QToolButton[popupMode="1"]{
    padding-right: 12px;
}
/* hover 状态 - MenuButtonPopup 模式的菜单按钮部分 */
SARibbonButtonGroupWidget > QToolButton[popupMode="1"]::menu-button:hover {
    background-color: {{sys-button-hover}};
}
/* pressed 状态 - MenuButtonPopup 模式的菜单按钮部分 */
SARibbonButtonGroupWidget > QToolButton[popupMode="1"]::menu-button:pressed {
    background-color: {{border-color}};
}
/* 直接弹出菜单模式，偏移8px，让下拉按钮能看到 */
SARibbonButtonGroupWidget > QToolButton[popupMode="2"] {
    padding-right: 8px;
}
/* 无菜单的按钮保持小边距 */
SARibbonButtonGroupWidget > QToolButton[popupMode="0"]{
    padding: 0 2px;
}

/*SARibbonQuickAccessBar*/
SARibbonQuickAccessBar {
  background-color: transparent;
}

/*SARibbonCtrlContainer*/
SARibbonCtrlContainer {
  background-color: transparent;
}

/*
SARibbonSeparatorWidget
注意，SARibbonSeparatorWidget的背景颜色是使用color
*/
SARibbonSeparatorWidget {
  color: {{separator}};
}

/*SARibbonCategory*/
SARibbonCategory {
  background-color: {{accent}};
  /*顶部有一条线*/
  border-top:1px solid {{content-bg}};
}
SARibbonCategory:focus {
  outline: none;
}

/*
SARibbonCategory下的SARibbonSeparatorWidget
注意，SARibbonSeparatorWidget的背景颜色是使用color
*/
SARibbonCategory > SARibbonSeparatorWidget {
  color: transparent;
}

/*SARibbonPanel*/

SARibbonPanel {
  background-color: {{content-bg}};
  border: none;
  color: {{text-color}};
}

SARibbonPanel > SARibbonButtonGroupWidget {
  border: 1px solid {{border-color}};
}

/*
SARibbonPanel下的SARibbonSeparatorWidget
注意，SARibbonSeparatorWidget的背景颜色是使用color
*/
SARibbonPanel > SARibbonSeparatorWidget {
  color: {{separator}};
}

/*SARibbonPanelLabel Panel下标题栏*/
SARibbonPanelLabel {
    background-color: {{content-hover-bg}};
    color: {{white}};
}

/*SARibbonPanelOptionButton*/
SARibbonPanelOptionButton {
  border:none;
  background-color: transparent;
  color:{{text-color}};
}

SARibbonPanelOptionButton:hover {
  background-color:{{sys-button-hover}};
}

/*SARibbonStackedWidget*/
SARibbonStackedWidget{
  border: 1pt solid {{accent}};
  border-top-width: 0px;
}
SARibbonStackedWidget:focus{
  outline: none;
}

/*SARibbonApplicationButton*/
SARibbonApplicationButton{
  border-radius:2px;
  color:{{text-color}};
  border-top-left-radius: 4px;
  border-top-right-radius: 4px;
  background-color: {{content-bg}};
}

SARibbonApplicationButton:hover{
  background-color: {{content-pressed-bg}};
}

SARibbonApplicationButton:pressed{
  background-color: {{content-pressed-bg}};
}

SARibbonApplicationButton:focus{
  outline: none;
}

SARibbonApplicationButton::menu-indicator {
  /*subcontrol-position: right;*/
  width:0px;
}

/*SARibbonTabBar*/
SARibbonTabBar{
    background-color: transparent;
}

SARibbonTabBar::tab {
  color: {{accent-text}};
  border:1px solid transparent;/*加上边框，否则选中后加入边框后会有1px的偏移*/
  background: transparent;
  margin-top: 0px;
  margin-right: 0px;
  margin-left: 5px;
  margin-bottom: 0px;
  min-width: 50px;
  padding-left: 5px;
  padding-right: 5px;
}

SARibbonTabBar::tab:selected {
  color: {{text-color}};
  background-color: {{content-bg}};
}

SARibbonTabBar::tab:hover:!selected {
  /*border:1px solid #344253;*/
  border-top:1px solid {{content-bg}};
  border-right:1px solid {{content-bg}};
  border-left:1px solid {{content-bg}};
  border-bottom:1px solid transparent;
  color: {{white}};
}

SARibbonTabBar::tab:!selected {
  color: {{accent-text}};
}

/*SARibbonToolButton*/

SARibbonToolButton{
    border:none;
    border-radius:4px;
    color:{{white}};
    background-color:{{content-bg}};
} 

SARibbonToolButton:focus {
  border: 1px solid {{border-color}};
  border-radius:4px;
}
SARibbonToolButton:pressed{
    border-radius:4px;
    color:{{white}};
    background-color: {{content-pressed-bg}};
}
SARibbonToolButton:checked{
    border-radius:4px;
    color:{{white}};
    border: 1px solid {{border-color}};
    background-color: {{content-pressed-bg}};
}
SARibbonToolButton:checked:hover{
    border-radius:4px;
    color:{{white}};
    border: 1px solid {{border-color}};
    background-color: {{content-hover-bg}};
}
SARibbonToolButton:hover {
    border-radius:4px;
    color:{{white}};
    background-color: {{content-pressed-bg}};
}


SARibbonGalleryButton{
  background-color:{{content-bg}};
  border: 1px solid {{content-pressed-bg}};
  color: {{text-color}};
}
SARibbonGalleryButton:hover{
  background-color:{{content-pressed-bg}};
  border: 1px solid {{border-color}};
  color: {{text-color}};
}


/*SARibbonMenu*/
SARibbonMenu {
  color:{{text-color}};
  background-color: {{content-hover-bg}};
}
SARibbonMenu::item {
  padding: 5px;
  background-color: {{content-bg}};
}
SARibbonMenu::item:selected {
  border: 1px solid {{border-color}};
  background-color: {{content-pressed-bg}};
}
SARibbonMenu::item:hover {
    color:{{text-color}};
    border: 1px solid transparent;
    background-color: {{content-pressed-bg}};
}
SARibbonMenu::icon{
    margin-left: 1px;
}

/*SARibbonGallery*/
SARibbonGallery {
  background-color: {{content-hover-bg}};
  color: {{text-color}};
  border: 1px solid {{menu-border}};
}

/*SARibbonGalleryGroup*/
SARibbonGalleryGroup {
  show-decoration-selected: 1;
  background-color: transparent;
  color: {{text-color}};
  border: 1px solid {{menu-border}};
}
SARibbonGalleryGroup::item {
  color: {{text-color}};
}
SARibbonGalleryGroup::item:selected {
  color: {{text-color}};
  background-color: {{content-pressed-bg}};
  border: 1px solid {{border-color}};
}
SARibbonGalleryGroup::item:hover {
  background-color: {{content-pressed-bg}};
  border: 1px solid transparent;
}


/*RibbonGalleryViewport*/

SARibbonGalleryViewport {
  background-color: {{content-hover-bg}};
}

/*Panel下QLineEdit的特化*/
SARibbonPanel > QLineEdit {
  border:1px solid {{accent}};
  background-color: {{content-hover-bg}};
  color: {{text-color}};
  selection-background-color: {{border-color}};
  selection-color: {{text-color}};
}
SARibbonPanel > QLineEdit:hover{
    border: 1px solid {{border-color}};
}

/*Panel下QCheckBox的特化*/
SARibbonPanel > QCheckBox{
    color:{{text-color}};
    background-color:transparent;
}

/*Panel下QRadioButton的特化*/
SARibbonPanel > QRadioButton{
    color:{{text-color}};
    background-color:transparent;
}

/*Panel下QComboBox的特化*/
SARibbonPanel > QComboBox {
  color : {{text-color}};
  border: 1px solid {{accent}};
  background-color: {{content-bg}};
}
SARibbonPanel > QComboBox:hover{
  border: 1px solid {{border-color}};
}
SARibbonPanel > QComboBox:editable {
  color : {{text-color}};
  background-color: {{content-hover-bg}};
  selection-background-color: {{border-color}};
  selection-color: {{text-color}};
}
SARibbonPanel > QComboBox::drop-down {
  subcontrol-origin: padding;
  subcontrol-position: top right;
  width: 1em;
  border: none;
}
SARibbonPanel > QComboBox::drop-down:hover {
  border: none;
  background-color: {{border-color}};
}
SARibbonPanel > QComboBox::down-arrow {
  image: url(:/SARibbon/image/resource/ArrowDown.png);
}

/*SARibbonSeparatorWidget*/

SARibbonSeparatorWidget {
  background-color: {{accent}};
}

/*SARibbonCategoryScrollButton*/
SARibbonCategoryScrollButton {
  border-radius:2px;
  border: 1px solid {{border-color}};
  color: {{text-color}};
  background-color: {{content-bg}};
}

SARibbonCategoryScrollButton[arrowType="3"] {
  border-right-width: 1px;
}

SARibbonCategoryScrollButton[arrowType="4"] {
  border-left-width: 1px;
}
SARibbonCategoryScrollButton:hover {
  background-color: {{content-pressed-bg}};
}
/*SARibbonSystemToolButton*/

SARibbonSystemToolButton {
  background-color: transparent;
  border:none;
}

SARibbonSystemToolButton:focus {
  outline: none;
}

/* 深色模式的系统按钮设置 */
/*Min*/
SARibbonSystemToolButton#SAMinimizeWindowButton {
  image: url(:/SARibbon/image/resource/Titlebar_Min_Hover.svg);
  padding: 4px;
}
SARibbonSystemToolButton#SAMinimizeWindowButton:hover{
  background-color: {{sys-button-hover}};
}
SARibbonSystemToolButton#SAMinimizeWindowButton:pressed{
  background-color: {{sys-button-pressed}};
}
/*Max*/
SARibbonSystemToolButton#SAMaximizeWindowButton {
    image: url(:/SARibbon/image/resource/Titlebar_Max_Hover.svg);
    padding: 4px;
}
SARibbonSystemToolButton#SAMaximizeWindowButton:hover {
    background-color: {{sys-button-hover}};
}
SARibbonSystemToolButton#SAMaximizeWindowButton:checked {
    image: url(:/SARibbon/image/resource/Titlebar_Normal_Hover.svg);
}


/*Close*/
SARibbonSystemToolButton#SACloseWindowButton {
    image: url(:/SARibbon/image/resource/Titlebar_Close_Hover.svg);
    padding: 4px;
}
SARibbonSystemToolButton#SACloseWindowButton:hover {
  background-color: {{close-bg}};
}
SARibbonSystemToolButton#SACloseWindowButton:pressed {
  background-color: {{close-bg-pressed}};
}